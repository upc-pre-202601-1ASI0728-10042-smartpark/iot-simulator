# ============================================================================
# Configuracion de SmartPark - Azure Digital Twins
# Copia este archivo a ".env" y completa los valores.
# Los scripts de Node cargan .env automaticamente (dotenv).
# Los scripts de PowerShell tambien lo leen (scripts/config.ps1).
# ============================================================================

# --- Azure (se usan al provisionar) ---
AZURE_SUBSCRIPTION_ID=
LOCATION=eastus2
RESOURCE_GROUP=rg-smartpark
ADT_INSTANCE_NAME=adt-smartpark

# Storage para el modelo 3D y la config de la escena (debe ser globalmente unico,
# 3-24 chars, solo minusculas y numeros). Ej: stsmartpark + tus iniciales + numero
STORAGE_ACCOUNT=stsmartparkXXXX
STORAGE_CONTAINER=3dscenes

# --- Se completan DESPUES de provisionar (01-provision-azure.ps1 los imprime) ---
# Host del data-plane de ADT, formato: <nombre>.api.<region>.digitaltwins.azure.net
ADT_HOST_NAME=

# --- Integracion con el Web Service (ASP.NET Core) ---
# Endpoint donde el simulador POSTea las alertas de humo (cadena de notificaciones)
WEB_SERVICE_SMOKE_URL=http://localhost:5080/api/v1/alerts/smoke
# API key del header X-Api-Key. DEBE coincidir con "Ingest:ApiKey" del Web Service
# (web-services/appsettings). Si el Web Service la deja vacia, la ingesta queda abierta.
WEB_SERVICE_API_KEY=

# --- Parametros del simulador IoT ---
SIM_TICK_MS=5000
SIM_SMOKE_PROBABILITY=0.0015
# Intensidad base del flujo vehicular (entradas/salidas esperadas por intervalo)
SIM_FLOW_INTENSITY=1.2
SIM_PEAK_HOURS=12,13,18,19,20
# Ventana (nro de muestras) de la media movil para la tendencia de ocupacion
SIM_TREND_WINDOW=6
# Umbral de baja ocupacion sostenida que dispara la recomendacion energetica (0..1)
SIM_LOW_OCCUPANCY=0.25
